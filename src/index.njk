---
layout: layouts/base.njk
title: Ana Sayfa
description: "Klinik Nöropsikolog Gülşah Özgenç — zihin, eylem ve dirence dair düşünceler, araştırmalar ve akademik içerikler."
---

{# ==========================================================================
   1. HERO
   ========================================================================== #}
<section id="hero" class="relative pt-28 md:pt-32 pb-24 md:pb-32 overflow-hidden {% if theme.show_grain_overlay %}grain-overlay{% endif %}">
  <div class="absolute inset-0 bg-vignette pointer-events-none"></div>

  <div class="container-academy relative grid lg:grid-cols-12 gap-12 items-center">

    <div class="lg:col-span-7 order-2 lg:order-1">
      <p class="eyebrow mb-6 flex items-center gap-3">
        <span class="divider"></span>
        {{ home.hero.eyebrow }}
      </p>

      <h1 class="heading-display text-cream-50 text-balance">
        {{ home.hero.headline_prefix }}
        <span class="italic text-burgundy-200">{{ home.hero.headline_accent }}</span>
        {{ home.hero.headline_suffix }}
      </h1>

      <p class="lede mt-8 max-w-2xl">{{ home.hero.lede | safe }}</p>

      <div class="mt-10 flex flex-wrap items-center gap-4">
        {% if home.hero.cta_primary_label %}
        <a href="{{ home.hero.cta_primary_href }}" class="btn-primary">
          {{ home.hero.cta_primary_label }}
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
        {% endif %}
        {% if home.hero.cta_secondary_label %}
        <a href="{{ home.hero.cta_secondary_href }}" class="btn-secondary">{{ home.hero.cta_secondary_label }}</a>
        {% endif %}
      </div>

      {% if home.hero.show_stats and home.hero.stats | length %}
      <dl class="mt-14 grid grid-cols-3 gap-8 max-w-lg border-t border-cream-100/8 pt-8">
        {% for stat in home.hero.stats %}
        <div>
          <dt class="eyebrow">{{ stat.label_top }}</dt>
          <dd class="font-serif text-2xl text-cream-50 mt-1">{{ stat.value }}</dd>
          <p class="text-xs text-cream-200/50 mt-1">{{ stat.label_bottom }}</p>
        </div>
        {% endfor %}
      </dl>
      {% endif %}
    </div>

    <div class="lg:col-span-5 order-1 lg:order-2 relative">
      <div class="relative aspect-[4/5] w-full max-w-md mx-auto">
        <div class="absolute -inset-3 ring-1 ring-burgundy-300/30 rounded-sm"></div>
        <div class="absolute inset-0 ring-1 ring-cream-100/10 rounded-sm
                    bg-gradient-to-br from-ink-200 via-ink-300 to-ink-500
                    overflow-hidden">
          {% if home.hero.portrait_image %}
          <img src="{{ home.hero.portrait_image }}" alt="{{ home.hero.portrait_alt }}"
               class="w-full h-full object-cover opacity-90 mix-blend-luminosity hover:mix-blend-normal hover:opacity-100 transition-all duration-700"
               onerror="this.style.display='none'" />
          {% endif %}
          <div class="absolute inset-0 bg-vignette pointer-events-none"></div>
          <figcaption class="absolute bottom-4 left-4 right-4 flex items-end justify-between text-cream-100/80">
            <span class="font-mono text-[10px] uppercase tracking-wider2">{{ home.hero.portrait_caption_left }}</span>
            <span class="font-serif italic text-sm">{{ home.hero.portrait_caption_right }}</span>
          </figcaption>
        </div>
      </div>
    </div>
  </div>

  <a href="#felsefe"
     class="absolute bottom-6 left-1/2 -translate-x-1/2 hidden md:flex flex-col items-center gap-2
            text-cream-200/50 hover:text-cream-100 transition-colors">
    <span class="font-mono text-[10px] uppercase tracking-wider2">Aşağı</span>
    <span class="block w-px h-10 bg-current"></span>
  </a>
</section>


{# ==========================================================================
   2. FELSEFE / HAKKINDA
   ========================================================================== #}
{% if home.philosophy.show %}
<section id="felsefe" class="section section-light relative overflow-hidden">
  <div class="container-academy grid md:grid-cols-12 gap-12">

    <aside class="md:col-span-4">
      <p class="eyebrow flex items-center gap-3">
        <span class="divider"></span> {{ home.philosophy.eyebrow }}
      </p>
      <h2 class="heading-section mt-6 text-balance">
        {{ home.philosophy.heading_prefix }}
        <span class="italic text-burgundy-400">{{ home.philosophy.heading_accent }}</span>
      </h2>
    </aside>

    <div class="md:col-span-7 md:col-start-6 max-w-prose2 text-ink-50/85 space-y-5 text-base md:text-lg leading-relaxed">
      {% for paragraph in home.philosophy.paragraphs %}
      <p>{{ paragraph | safe }}</p>
      {% endfor %}

      {% if home.philosophy.principles | length %}
      <ul class="grid grid-cols-2 gap-4 pt-6 mt-8 border-t border-ink-50/15">
        {% for p in home.philosophy.principles %}
        <li class="flex items-start gap-3">
          <span class="mt-1 w-2 h-2 rounded-full bg-burgundy-400 shrink-0"></span>
          <span>
            <strong class="font-medium">{{ p.title }}</strong><br/>
            <span class="text-sm text-ink-50/60">{{ p.subtitle }}</span>
          </span>
        </li>
        {% endfor %}
      </ul>
      {% endif %}
    </div>
  </div>
</section>
{% endif %}


{# ==========================================================================
   3. AKADEMİK PORTFOLYO
   ========================================================================== #}
{% if home.research.show %}
<section id="arastirma" class="section relative overflow-hidden {% if theme.show_grain_overlay %}grain-overlay{% endif %}">
  <div class="container-academy">

    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-14">
      <div class="max-w-2xl">
        <p class="eyebrow flex items-center gap-3">
          <span class="divider"></span> {{ home.research.eyebrow }}
        </p>
        <h2 class="heading-section mt-6 text-cream-50 text-balance">
          {{ home.research.heading_prefix }}
          <span class="italic text-burgundy-200">{{ home.research.heading_accent }}</span>
        </h2>
        <p class="lede mt-6">{{ home.research.lede | safe }}</p>
      </div>
      {% if home.research.all_publications_label %}
      <a href="{{ home.research.all_publications_url }}" class="btn-ghost self-start md:self-end">
        {{ home.research.all_publications_label }}
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
      {% endif %}
    </div>

    <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {% for paper in papers %}
        <li>
          <article class="paper-card h-full flex flex-col">
            <div class="flex items-center justify-between mb-5">
              <span class="inline-flex items-center justify-center w-10 h-10 rounded-sm
                           bg-burgundy-400/10 ring-1 ring-burgundy-300/30 text-burgundy-200">
                {% if paper.icon == "brain" %}
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 4a3 3 0 0 0-3 3v1a3 3 0 0 0-2 5 3 3 0 0 0 2 5v1a3 3 0 0 0 6 0V4a3 3 0 0 0-3 0Z"/><path d="M15 4a3 3 0 0 1 3 3v1a3 3 0 0 1 2 5 3 3 0 0 1-2 5v1a3 3 0 0 1-6 0"/></svg>
                {% elif paper.icon == "spiral" %}
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 12m-2 0a2 2 0 1 0 4 0 2 2 0 1 0 -4 0"/><path d="M12 12m-5 0a5 5 0 1 0 10 0 5 5 0 1 0 -10 0"/><path d="M12 12m-9 0a9 9 0 1 0 18 0"/></svg>
                {% elif paper.icon == "compass" %}
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="m14.5 9.5-2 5-5 2 2-5z"/></svg>
                {% elif paper.icon == "eye" %}
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s4-7 10-7 10 7 10 7-4 7-10 7S2 12 2 12Z"/><circle cx="12" cy="12" r="3"/></svg>
                {% elif paper.icon == "thread" %}
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6c4 0 4 12 8 12s4-12 8-12"/></svg>
                {% elif paper.icon == "moon" %}
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"/></svg>
                {% else %}
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="8"/></svg>
                {% endif %}
              </span>
              <span class="font-mono text-[10px] uppercase tracking-wider2 text-cream-200/50">
                {{ paper.year }}
              </span>
            </div>

            <p class="eyebrow text-cream-200/50">{{ paper.type }}</p>
            <h3 class="font-serif text-xl text-cream-50 mt-2 leading-snug">
              {{ paper.title }}
            </h3>
            <p class="mt-3 text-sm text-cream-200/65 leading-relaxed flex-1">
              {{ paper.summary }}
            </p>
            <div class="mt-6 flex items-center justify-between pt-5 border-t border-cream-100/8">
              <span class="text-xs text-cream-200/50 italic">{{ paper.venue }}</span>
              {% if paper.url %}
              <a href="{{ paper.url }}" class="text-xs font-mono uppercase tracking-wider2 text-burgundy-200 hover:text-burgundy-100">
                Oku →
              </a>
              {% endif %}
            </div>
          </article>
        </li>
      {% endfor %}
    </ul>
  </div>
</section>
{% endif %}


{# ==========================================================================
   4. MEDYA / VIDEO
   ========================================================================== #}
{% if home.media.show %}
<section id="medya" class="section bg-ink-500 relative overflow-hidden">
  <div class="container-academy grid lg:grid-cols-12 gap-12 items-start">

    <div class="lg:col-span-5">
      <p class="eyebrow flex items-center gap-3">
        <span class="divider"></span> {{ home.media.eyebrow }}
      </p>
      <h2 class="heading-section mt-6 text-cream-50 text-balance">
        {{ home.media.heading_prefix }}
        <span class="italic text-burgundy-200">{{ home.media.heading_accent }}</span>
      </h2>
      <p class="lede mt-6">{{ home.media.lede | safe }}</p>

      {% if home.media.tags | length %}
      <ul class="mt-8 space-y-4 text-cream-200/75 text-sm">
        {% for tag in home.media.tags %}
        <li class="flex items-start gap-3">
          <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-burgundy-300 shrink-0"></span>
          {{ tag }}
        </li>
        {% endfor %}
      </ul>
      {% endif %}
    </div>

    <div class="lg:col-span-7 space-y-5">
      {% if home.media.main_video.id %}
        {% youtube home.media.main_video.id, home.media.main_video.title %}
      {% endif %}
      {% if home.media.side_videos | length %}
      <div class="grid sm:grid-cols-2 gap-5">
        {% for v in home.media.side_videos %}
          {% youtube v.id, v.title %}
        {% endfor %}
      </div>
      {% endif %}
    </div>
  </div>
</section>
{% endif %}


{# ==========================================================================
   5. BÜLTEN
   ========================================================================== #}
{% if home.newsletter.show %}
<section id="bulten" class="section section-light relative overflow-hidden">
  <div class="container-academy max-w-3xl text-center">
    <p class="eyebrow flex items-center justify-center gap-3">
      <span class="divider"></span> {{ site.newsletter.title }} <span class="divider"></span>
    </p>
    <h2 class="heading-section mt-6 text-balance">
      {{ home.newsletter.heading_prefix }}
      <span class="italic text-burgundy-400">{{ home.newsletter.heading_accent }}</span>
    </h2>
    <p class="lede mt-6 mx-auto">{{ site.newsletter.description }}</p>

    <form class="mt-10 flex flex-col sm:flex-row gap-3 sm:gap-2 max-w-xl mx-auto"
          action="https://formspree.io/f/{{ site.form.formspreeId }}" method="POST">
      <label class="sr-only" for="newsletter-email">E-posta</label>
      <input id="newsletter-email" name="email" type="email" required
             placeholder="ornek@eposta.com"
             class="input flex-1 text-center sm:text-left" />
      <input type="hidden" name="_subject" value="Bülten kaydı" />
      <button type="submit" class="btn-primary justify-center">{{ home.newsletter.submit_label }}</button>
    </form>

    <p class="mt-4 text-xs text-ink-50/55">{{ home.newsletter.footnote }}</p>
  </div>
</section>
{% endif %}


{# ==========================================================================
   6. İLETİŞİM
   ========================================================================== #}
{% if home.contact.show %}
<section id="iletisim" class="section relative overflow-hidden {% if theme.show_grain_overlay %}grain-overlay{% endif %}">
  <div class="container-academy grid lg:grid-cols-12 gap-12">

    <div class="lg:col-span-5">
      <p class="eyebrow flex items-center gap-3">
        <span class="divider"></span> {{ home.contact.eyebrow }}
      </p>
      <h2 class="heading-section mt-6 text-cream-50 text-balance">
        {{ home.contact.heading_prefix }}
        <span class="italic text-burgundy-200">{{ home.contact.heading_accent }}</span>
      </h2>
      <p class="lede mt-6">{{ home.contact.lede | safe }}</p>

      {% if home.contact.info | length %}
      <ul class="mt-10 space-y-4 text-cream-200/75 text-sm">
        {% for item in home.contact.info %}
        <li class="flex items-center gap-3">
          {% if item.icon == "envelope" %}
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" class="text-burgundy-200 shrink-0"><path d="M4 6h16v12H4z"/><path d="m4 7 8 6 8-6"/></svg>
          {% elif item.icon == "clock" %}
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" class="text-burgundy-200 shrink-0"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
          {% elif item.icon == "pin" %}
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" class="text-burgundy-200 shrink-0"><path d="M12 2a8 8 0 0 0-8 8c0 6 8 12 8 12s8-6 8-12a8 8 0 0 0-8-8Z"/><circle cx="12" cy="10" r="2.5"/></svg>
          {% elif item.icon == "phone" %}
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" class="text-burgundy-200 shrink-0"><path d="M5 4h4l2 5-3 2a12 12 0 0 0 5 5l2-3 5 2v4a2 2 0 0 1-2 2A18 18 0 0 1 3 6a2 2 0 0 1 2-2Z"/></svg>
          {% else %}
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" class="text-burgundy-200 shrink-0"><circle cx="12" cy="12" r="8"/></svg>
          {% endif %}
          {% if item.href %}
            <a href="{{ item.href }}" class="hover:text-cream-50">{{ item.text }}</a>
          {% else %}
            <span>{{ item.text }}</span>
          {% endif %}
        </li>
        {% endfor %}
      </ul>
      {% endif %}
    </div>

    <div class="lg:col-span-7">
      {% if site.form.typeformId %}
        <div data-tf-live="{{ site.form.typeformId }}" class="min-h-[520px]"></div>
        <script src="//embed.typeform.com/next/embed.js"></script>
      {% else %}
        <form action="https://formspree.io/f/{{ site.form.formspreeId }}" method="POST"
              class="bg-ink-300/50 ring-1 ring-cream-100/8 rounded-sm p-6 md:p-10 space-y-6 backdrop-blur-sm">

          <div>
            <label for="contact-name" class="eyebrow">İsim</label>
            <input id="contact-name" name="name" type="text" required
                   placeholder="Ad Soyad" class="input-dark mt-2" />
          </div>

          <div>
            <label for="contact-email" class="eyebrow">E-posta</label>
            <input id="contact-email" name="email" type="email" required
                   placeholder="ornek@eposta.com" class="input-dark mt-2" />
          </div>

          <div>
            <label for="contact-nature" class="eyebrow">Talebin niteliği</label>
            <select id="contact-nature" name="nature" required
                    class="input-dark mt-2 appearance-none cursor-pointer
                           [&>option]:bg-ink-400 [&>option]:text-cream-100">
              <option value="" disabled selected>Seçiniz</option>
              {% for opt in home.contact.form_options %}
              <option value="{{ opt.value }}">{{ opt.label }}</option>
              {% endfor %}
            </select>
          </div>

          <div>
            <label for="contact-message" class="eyebrow">Mesaj</label>
            <textarea id="contact-message" name="message" rows="5" required
                      placeholder="Birkaç cümleyle bağlam..."
                      class="input-dark mt-2 resize-none"></textarea>
          </div>

          <input type="hidden" name="_subject" value="Yeni iletişim formu mesajı" />

          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 pt-2">
            <p class="text-xs text-cream-200/50 max-w-sm">{{ home.contact.consent_text }}</p>
            <button type="submit" class="btn-primary">
              {{ home.contact.submit_label }}
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </button>
          </div>
        </form>
      {% endif %}
    </div>
  </div>
</section>
{% endif %}
