{
  "name": "gulsahozgenc-site",
  "version": "1.0.0",
  "description": "Klinik Norropsikolog Gulsah Ozgenc - kisisel portfolyo sitesi.",
  "private": true,
  "scripts": {
    "clean": "rm -rf _site",
    "build:css": "postcss src/assets/css/tailwind.css -o _site/assets/css/style.css",
    "watch:css": "postcss src/assets/css/tailwind.css -o _site/assets/css/style.css --watch",
    "build:11ty": "eleventy",
    "watch:11ty": "eleventy --serve --port=8080",
    "build": "npm run clean && npm run build:11ty && NODE_ENV=production npm run build:css",
    "dev": "npm-run-all --parallel watch:11ty watch:css",
    "start": "npm run dev"
  },
  "devDependencies": {
    "@11ty/eleventy": "^2.0.1",
    "autoprefixer": "^10.4.19",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.38",
    "postcss-cli": "^11.0.0",
    "tailwindcss": "^3.4.4"
  }
}
